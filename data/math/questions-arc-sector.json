    "type": "choice",
    "difficulty": 1,
    "question": "已知一个圆的半径为5 cm，弧长为π cm，则该弧所对的圆心角为多少度？",
    "options": [
      "36°",
      "72°",
      "180°",
      "360°"
    ],
    "answer": "36°",
    "steps": [
      "弧长公式：L = rθ，其中L为弧长，r为半径，θ为圆心角（弧度制）。",
      "将已知条件代入公式：π = 5θ。",
      "解得θ = π/5（弧度）。",
      "将弧度转换为角度：θ = (π/5) * (180/π) = 36°。"
    ],
    "common_errors": [
      {
        "error": "忘记将弧度转换为角度。",
        "hint": "记住1弧度 = 180/π度。"
      },
      {
        "error": "计算错误，例如将π/5误算为5/π。",
        "hint": "仔细检查分数计算。"
      }
    ],
    "exam_frequency": 3
  },
