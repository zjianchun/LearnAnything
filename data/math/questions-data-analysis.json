    "type": "choice",
    "difficulty": 1,
    "question": "一组数据为5, 7, 7, 8, 10, 12，则这组数据的众数是？",
    "options": [
      "A. 5",
      "B. 7",
      "C. 8",
      "D. 10"
    ],
    "answer": "B. 7",
    "steps": [
      "众数是指数据中出现次数最多的数。",
      "在5, 7, 7, 8, 10, 12中，7出现了两次，其他数字都只出现了一次。",
      "因此，众数是7。"
    ],
    "common_errors": [
      {
        "error": "误将出现次数最多的数字当成众数。",
        "hint": "确保数字在数据中出现的次数最多。"
      }
    ],
