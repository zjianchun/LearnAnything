    "type": "choice",
    "difficulty": 1,
    "question": "在Rt△ABC中，∠C=90°，若sinA=3/5，则cosA的值为多少？",
    "options": [
      "A. 3/5",
      "B. 4/5",
      "C. 5/4",
      "D. 5/3"
    ],
    "answer": "B. 4/5",
    "steps": [
      "1. 根据sinA=3/5，设直角边BC=3k，斜边AB=5k。",
      "2. 根据勾股定理，AC^2 + BC^2 = AB^2，求出AC=4k。",
      "3. cosA = AC/AB = 4k/5k = 4/5。"
    ],
    "common_errors": [
      {
        "error": "误用sinA=3/5直接求cosA。",
        "hint": "需要先求出直角边AC，再计算cosA。"
      }
    ],
    "exam_frequency": 4
  },
