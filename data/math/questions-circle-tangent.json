    "type": "choice",
    "difficulty": 1,
    "question": "已知圆的半径为5，圆心到直线的距离为3，则直线与圆的位置关系是：",
    "options": [
      "A. 相交",
      "B. 相切",
      "C. 相离",
      "D. 无法确定"
    ],
    "answer": "A. 相交",
    "steps": [
      "1. 判断直线与圆的位置关系，需要比较圆心到直线的距离d与圆的半径r。",
      "2. 已知d=3，r=5。",
      "3. 当d<r时，直线与圆相交；当d=r时，直线与圆相切；当d>r时，直线与圆相离。",
      "4. 因为3<5，所以直线与圆相交。"
    ],
    "common_errors": [
      {
        "error": "误认为d=r时直线与圆相交",
        "hint": "注意区分d=r时是相切而不是相交。"
      },
      {
        "error": "忘记比较d与r",
        "hint": "一定要先计算d与r，再进行比较。"
      }
    ],
    "exam_frequency": 5
  },
