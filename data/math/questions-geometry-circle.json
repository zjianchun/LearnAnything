    "type": "choice",
    "difficulty": 1,
    "question": "已知圆的半径为5，圆心到直线的距离为3，则该直线与圆的位置关系是？",
    "options": [
      "A. 相交",
      "B. 相切",
      "C. 相离",
      "D. 无法确定"
    ],
    "answer": "A. 相交",
    "steps": [
      "1. 圆的半径r=5，圆心到直线的距离d=3。",
      "2. 比较d与r的大小：d < r。",
      "3. 当d < r时，直线与圆相交。"
    ],
    "common_errors": [
      {
        "error": "误认为d=r时直线与圆相切",
        "hint": "注意区分d=r（相切）、d<r（相交）和d>r（相离）的情况。"
      }
    ],
    "exam_frequency": 4
