    "type": "choice",
    "difficulty": 1,
    "question": "如图所示，电源电压为6V，电阻R1为2Ω，R2为4Ω，则通过R1的电流为多少？",
    "options": [
      "A. 1A",
      "B. 2A",
      "C. 3A",
      "D. 4A"
    ],
    "answer": "A. 1A",
    "steps": [
      "根据欧姆定律，I=U/R",
      "总电压为6V，R1为2Ω，通过R1的电流I1=6V/2Ω=3A",
      "考虑电路为串联，R2的存在影响电流大小",
      "总电阻R=R1+R2=2Ω+4Ω=6Ω",
      "总电流I=6V/6Ω=1A",
      "因此，通过R1的电流为1A"
    ],
    "common_errors": [
      {
        "error": "直接用R1计算电流，忽略R2的影响",
        "hint": "注意电路为串联，R2会影响总电阻和总电流"
      },
      {
        "error": "未正确应用欧姆定律",
        "hint": "确保电压、电流和电阻的关系正确"
      }
    ],
    "exam_frequency": 5
  },
