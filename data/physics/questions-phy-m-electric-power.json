    "answer": "C. 1.6W",
    "steps": [
      "1. 计算总电阻：R总=R1+R2=30Ω。",
      "2. 计算总电流：I=U/R总=12V/30Ω=0.4A。",
      "3. 计算R1的电功率：P1=I²R1=(0.4A)²×10Ω=1.6W。"
    ],
    "common_errors": [
