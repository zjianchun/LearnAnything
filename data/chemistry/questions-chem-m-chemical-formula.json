    "type": "choice",
    "difficulty": 1,
    "question": "下列物质中，氯元素的化合价为+1价的是：",
    "options": [
      "A. HCl",
      "B. Cl2",
      "C. HClO",
      "D. KClO3"
    ],
    "answer": "C. HClO",
    "steps": [
      "1. 确定氯元素在不同物质中的化合价。",
      "2. HCl中，H为+1价，Cl为-1价。",
      "3. Cl2为单质，化合价为0。",
      "4. HClO中，H为+1价，O为-2价，Cl为+1价。",
      "5. KClO3中，K为+1价，O为-2价，Cl为+5价。"
    ],
    "common_errors": [
      {
        "error": "误认为HCl中Cl的化合价为+1",
        "hint": "H的化合价通常为+1，Cl的化合价应为-1。"
      },
      {
        "error": "误认为Cl2中Cl的化合价为+2",
        "hint": "单质的化合价为0。"
      }
    ],
    "exam_frequency": 5
  },
