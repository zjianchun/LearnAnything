<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 360" width="640" height="360">
  <rect width="640" height="360" fill="#0a0a1e"/>
  <text x="320" y="28" text-anchor="middle" font-family="Arial,sans-serif" font-size="20" font-weight="bold" fill="white">酸碱中和反应 · 微观示意</text>
  <!-- LEFT: H+ ion cluster -->
  <text x="90" y="60" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" fill="#f87171">酸溶液 (HCl)</text>
  <circle cx="70" cy="130" r="36" fill="#fde047" stroke="#facc15" stroke-width="3"/>
  <text x="70" y="126" text-anchor="middle" font-family="Arial,sans-serif" font-size="20" font-weight="bold" fill="#1a1a1a">H⁺</text>
  <text x="70" y="148" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#fef9c3">氢离子</text>
  <text x="70" y="162" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#fde047">+1价</text>
  <circle cx="130" cy="110" r="32" fill="#fde047" stroke="#facc15" stroke-width="2"/>
  <text x="130" y="106" text-anchor="middle" font-family="Arial,sans-serif" font-size="18" font-weight="bold" fill="#1a1a1a">H⁺</text>
  <circle cx="100" cy="190" r="30" fill="#fde047" stroke="#facc15" stroke-width="2"/>
  <text x="100" y="186" text-anchor="middle" font-family="Arial,sans-serif" font-size="17" font-weight="bold" fill="#1a1a1a">H⁺</text>
  <!-- Cl- ions -->
  <circle cx="50" cy="210" r="30" fill="#86efac" stroke="#4ade80" stroke-width="2"/>
  <text x="50" y="206" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#1a1a1a">Cl⁻</text>
  <circle cx="120" cy="240" r="28" fill="#86efac" stroke="#4ade80" stroke-width="2"/>
  <text x="120" y="236" text-anchor="middle" font-family="Arial,sans-serif" font-size="15" font-weight="bold" fill="#1a1a1a">Cl⁻</text>
  <!-- PLUS -->
  <text x="220" y="175" text-anchor="middle" font-family="Arial,sans-serif" font-size="32" fill="white">+</text>
  <!-- MIDDLE: OH- ion cluster -->
  <text x="360" y="60" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" fill="#60a5fa">碱溶液 (NaOH)</text>
  <circle cx="330" cy="120" r="34" fill="#60a5fa" stroke="#3b82f6" stroke-width="3"/>
  <text x="330" y="116" text-anchor="middle" font-family="Arial,sans-serif" font-size="18" font-weight="bold" fill="white">OH⁻</text>
  <text x="330" y="138" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#dbeafe">氢氧根离子</text>
  <text x="330" y="152" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#93c5fd">-1价</text>
  <circle cx="400" cy="100" r="30" fill="#60a5fa" stroke="#3b82f6" stroke-width="2"/>
  <text x="400" y="96" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="white">OH⁻</text>
  <circle cx="380" cy="180" r="28" fill="#60a5fa" stroke="#3b82f6" stroke-width="2"/>
  <text x="380" y="176" text-anchor="middle" font-family="Arial,sans-serif" font-size="15" font-weight="bold" fill="white">OH⁻</text>
  <!-- Na+ ions -->
  <circle cx="430" cy="220" r="28" fill="#c084fc" stroke="#a855f7" stroke-width="2"/>
  <text x="430" y="216" text-anchor="middle" font-family="Arial,sans-serif" font-size="15" font-weight="bold" fill="white">Na⁺</text>
  <circle cx="340" cy="240" r="26" fill="#c084fc" stroke="#a855f7" stroke-width="2"/>
  <text x="340" y="236" text-anchor="middle" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="white">Na⁺</text>
  <!-- ARROW -->
  <text x="480" y="175" text-anchor="middle" font-family="Arial,sans-serif" font-size="28" fill="#4ade80">→</text>
  <!-- RIGHT: Products -->
  <text x="570" y="60" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" fill="#4ade80">反应产物</text>
  <!-- H2O molecules -->
  <circle cx="530" cy="120" r="36" fill="#22d3ee" stroke="#06b6d4" stroke-width="3"/>
  <text x="530" y="113" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#1a1a1a">H₂O</text>
  <text x="530" y="132" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#cffafe">水分子</text>
  <text x="530" y="146" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#67e8f9">中性</text>
  <circle cx="590" cy="140" r="28" fill="#22d3ee" stroke="#06b6d4" stroke-width="2"/>
  <text x="590" y="136" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#1a1a1a">H₂O</text>
  <circle cx="560" cy="200" r="30" fill="#22d3ee" stroke="#06b6d4" stroke-width="2"/>
  <text x="560" y="196" text-anchor="middle" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="#1a1a1a">H₂O</text>
  <!-- NaCl -->
  <circle cx="600" cy="240" r="30" fill="#f0abfc" stroke="#d946ef" stroke-width="2"/>
  <text x="600" y="236" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#1a1a1a">NaCl</text>
  <text x="600" y="252" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" fill="#f5d0fe">盐</text>
  <circle cx="540" cy="250" r="26" fill="#86efac" stroke="#4ade80" stroke-width="2"/>
  <text x="540" y="246" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#1a1a1a">Na⁺</text>
  <circle cx="570" cy="290" r="24" fill="#86efac" stroke="#4ade80" stroke-width="2"/>
  <text x="570" y="286" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" font-weight="bold" fill="#1a1a1a">Cl⁻</text>
  <!-- Equation at bottom -->
  <rect x="100" y="310" width="440" height="38" rx="8" fill="#1e1b4b" stroke="#4c1d95" stroke-width="1"/>
  <text x="320" y="334" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" fill="#c4b5fd">HCl + NaOH → NaCl + H₂O</text>
  <text x="320" y="350" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" fill="#86efac">酸 + 碱 = 盐 + 水（中和反应通式）</text>
</svg>